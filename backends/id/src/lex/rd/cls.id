// Character classes. A byte code is whitespace, a digit, or an identifier-start
// (letter or underscore); '-' and digits continue an identifier (see word.id).
is_space(int c) {
} return int c == 32 || c == 9 || c == 10 || c == 13;

is_digit(int c) {
} return int c >= 48 && c <= 57;

is_alpha(int c) {
} return int (c >= 65 && c <= 90) || (c >= 97 && c <= 122) || c == 95;
