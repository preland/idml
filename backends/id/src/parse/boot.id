// One-time state setup: the framebuffer, the header scratch, the paint counter,
// and the render/-rects mode flag.
init_all() {
  fb_init(640, 460);
  hd_init();
  init_rest();
} return void;

init_rest() {
  paint_init();
  mode_reset();
} return void;

mode_reset() {
  export int[] mode = [0];
} return void;
