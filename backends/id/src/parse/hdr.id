// Read one node header: `Name(args)[h,w,align]`, leaving the cursor just past
// the closing `]`. The node's direction comes from its name; args are skipped;
// the first two numbers inside `[ ]` are its height% and width%.
read_hdr() {
  int dir = dir_of(text_at(pos()));
  skip_hdr(dir);
} return void;

skip_hdr(int dir) {
  goto_tok("[");
  read_two(dir);
} return void;

goto_tok(string s) {
  while(cur_is(s) == 0) {
    adv();
  }
} return void;
