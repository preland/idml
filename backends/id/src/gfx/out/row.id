// One PPM row: split each 0xRRGGBB pixel back into "r g b" decimal channels
// (division/modulo, since id has no bitwise ops) and print one line per pixel.

dump_row(int y) {
  int x = 0;
  while(x < (import gw)) {
    dump_px(x, y);
    x = x + 1;
  }
} return void;

dump_px(int x, int y) {
  int c = (import fb)[px_idx(x, y)];
  print((c / 65536) + " " + (c / 256 % 256) + " " + (c % 256));
} return void;
