// A filled rectangle at (x,y), size w*h, colour c. Per-pixel clipping lives in
// pset, so callers may pass rectangles that spill past the surface edges.

fill_rect(int x, int y, int w, int h, int c) {
  int j = 0;
  while(j < h) {
    rect_row(x, y + j, w, c);
    j = j + 1;
  }
} return void;

rect_row(int x, int y, int w, int c) {
  int i = 0;
  while(i < w) {
    pset(x + i, y, c);
    i = i + 1;
  }
} return void;
