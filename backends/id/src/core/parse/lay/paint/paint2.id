// Fill the background only when the node declares one (-1 = transparent), and
// draw the pending text label vertically centred, left-padded, in the fg colour.
fill_bg(int x, int y, int w, int h, int bg) {
  int r = 0;
  if(bg >= 0) {
    fill_rect(x, y, w, h, bg);
  }
} return void;

draw_label(int x, int y, int w, int h) {
  int r = 0;
  if(has_text()) {
    put_text(x, y, h);
  }
} return void;

has_text() {
} return int len((import ptext)[0]) > 0;
